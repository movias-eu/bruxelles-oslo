# RML mapping: unified live-feed measurement rows -> OSLO Verkeersmeting RDF.
#
# Feed-agnostic: the preprocessor (TLC or DAI) emits one row schema, so this one
# mapping serves both. Ported from the PR #1 YARRRML tlc.yml/dai.yml (Morph-KGC),
# now for RMLMapper. count -> impl:Verkeerstelling (tellingresultaat),
# speed -> impl:Verkeerssnelheidsmeting (OM_Observation.result, Speed km/h).
# Sub-maps join on measSubject (unique per measurement). sensor/vehicle are
# per-row (TLC=inductielus/auto, DAI=standaard_Camera/auto).

@base <http://example.org/rules/> .
@prefix rr:          <http://www.w3.org/ns/r2rml#> .
@prefix rml:         <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:          <http://semweb.mmlab.be/ns/ql#> .
@prefix verkeer:     <https://data.vlaanderen.be/ns/verkeersmetingen#> .
@prefix impl:        <https://implementatie.data.vlaanderen.be/ns/verkeersmetingen-uitwisseling#> .
@prefix iso19156-ob: <http://def.isotc211.org/iso19156/2011/Observation#> .
@prefix iso19103-mp: <http://def.isotc211.org/iso19103/2005/MeasureProfile#> .
@prefix sosa:        <http://www.w3.org/ns/sosa/> .
@prefix terms:       <http://purl.org/dc/terms/> .
@prefix schema:      <http://schema.org/> .
@prefix cdt:         <https://w3id.org/cdt/> .
@prefix time:        <http://www.w3.org/2006/time#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix VkmVerkeersKenmerkType: <https://data.vlaanderen.be/id/concept/VkmVerkeersKenmerkType/> .
@prefix VkmMeetInstrumentType:  <https://data.vlaanderen.be/id/concept/VkmMeetInstrumentType/> .
@prefix VkmVoertuigType:        <https://data.vlaanderen.be/id/concept/VkmVoertuigType/> .
@prefix LinkDirectionValue:     <http://inspire.ec.europa.eu/codelist/LinkDirectionValue/> .

# --- Count observation (volume -> aantal): impl:Verkeerstelling ---------------
<#Verkeerstelling>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.counts[*]" ] ;
    rr:subjectMap [
        rr:template "http://example.org/id/measurement/{measSubject}" ;
        rr:class verkeer:Verkeersmeting ;
        rr:class impl:Verkeerstelling
    ] ;
    rr:predicateObjectMap [
        rr:predicate verkeer:geobserveerdObject ;
        rr:objectMap [ rr:template "http://example.org/id/measureLocation/{locId}" ; rr:termType rr:IRI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sosa:madeBySensor ;
        rr:objectMap [ rr:parentTriplesMap <#Sensor> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iso19156-ob:OM_Observation.phenomenonTime ;
        rr:objectMap [ rr:parentTriplesMap <#PhenomenonTime> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerstelling.geobserveerdKenmerk ;
        rr:objectMap [ rr:parentTriplesMap <#KenmerkCount> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerstelling.tellingresultaat ;
        rr:objectMap [ rml:reference "value" ; rr:datatype xsd:double ]
    ] .

# --- Speed observation (speed -> snelheid): impl:Verkeerssnelheidsmeting -------
<#Verkeerssnelheidsmeting>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.speeds[*]" ] ;
    rr:subjectMap [
        rr:template "http://example.org/id/measurement/{measSubject}" ;
        rr:class verkeer:Verkeersmeting ;
        rr:class impl:Verkeerssnelheidsmeting
    ] ;
    rr:predicateObjectMap [
        rr:predicate verkeer:geobserveerdObject ;
        rr:objectMap [ rr:template "http://example.org/id/measureLocation/{locId}" ; rr:termType rr:IRI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sosa:madeBySensor ;
        rr:objectMap [ rr:parentTriplesMap <#Sensor> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iso19156-ob:OM_Observation.phenomenonTime ;
        rr:objectMap [ rr:parentTriplesMap <#PhenomenonTime> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iso19156-ob:OM_Observation.result ;
        rr:objectMap [ rr:parentTriplesMap <#SpeedResult> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerssnelheidsmeting.geobserveerdKenmerk ;
        rr:objectMap [ rr:parentTriplesMap <#KenmerkSpeed> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] .

# --- Shared sub-resources (iterate all measurements, joined by measSubject) ----
<#Sensor>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.measurements[*]" ] ;
    rr:subjectMap [ rr:template "sensor/{measSubject}" ; rr:termType rr:BlankNode ; rr:class sosa:Sensor ] ;
    rr:predicateObjectMap [
        rr:predicate terms:type ;
        rr:objectMap [ rr:template "https://data.vlaanderen.be/id/concept/VkmMeetInstrumentType/{sensor}" ; rr:termType rr:IRI ]
    ] .

<#PhenomenonTime>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.measurements[*]" ] ;
    rr:subjectMap [ rr:template "phentime/{measSubject}" ; rr:termType rr:BlankNode ; rr:class time:TemporalEntity ] ;
    rr:predicateObjectMap [
        rr:predicate time:hasBeginning ;
        rr:objectMap [ rr:parentTriplesMap <#BeginInstant> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] ;
    # bike_live uses an explicit end instant (the device timestamp) instead of a
    # duration -- the cumulative count's window ends when the file was generated.
    rr:predicateObjectMap [
        rr:predicate time:hasEnd ;
        rr:objectMap [ rr:parentTriplesMap <#EndInstant> ;
            rr:joinCondition [ rr:child "measSubject" ; rr:parent "measSubject" ] ]
    ] .

<#BeginInstant>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.measurements[*]" ] ;
    rr:subjectMap [ rr:template "instant-begin/{measSubject}" ; rr:termType rr:BlankNode ; rr:class time:Instant ] ;
    rr:predicateObjectMap [
        rr:predicate time:inXSDDateTimeStamp ;
        rr:objectMap [ rml:reference "startISO" ; rr:datatype xsd:dateTime ]
    ] .

<#EndInstant>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.measurements[*]" ] ;
    rr:subjectMap [ rr:template "instant-end/{measSubject}" ; rr:termType rr:BlankNode ; rr:class time:Instant ] ;
    rr:predicateObjectMap [
        rr:predicate time:inXSDDateTimeStamp ;
        rr:objectMap [ rml:reference "endISO" ; rr:datatype xsd:dateTime ]
    ] .

<#SpeedResult>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.speeds[*]" ] ;
    rr:subjectMap [ rr:template "speedresult/{measSubject}" ; rr:termType rr:BlankNode ; rr:class iso19103-mp:Speed ] ;
    rr:predicateObjectMap [
        rr:predicate schema:unitCode ;
        rr:objectMap [ rr:constant "km/h" ; rr:datatype cdt:ucumunit ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:value ;
        rr:objectMap [ rml:reference "value" ; rr:datatype xsd:double ]
    ] .

<#KenmerkCount>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.counts[*]" ] ;
    rr:subjectMap [ rr:template "kenmerk/{measSubject}" ; rr:termType rr:BlankNode ; rr:class impl:Verkeerstellingkenmerk ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerstellingkenmerk.kenmerktype ;
        rr:objectMap [ rr:constant VkmVerkeersKenmerkType:aantal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate verkeer:voertuigType ;
        rr:objectMap [ rr:template "https://data.vlaanderen.be/id/concept/VkmVoertuigType/{vehicle}" ; rr:termType rr:IRI ]
    ] ;
    # measure direction: HARD-CODED to bothDirections (the feeds carry no
    # reliable per-measurement direction).
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerstellingkenmerk.meetrichting ;
        rr:objectMap [ rr:constant LinkDirectionValue:bothDirections ]
    ] .

<#KenmerkSpeed>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.speeds[*]" ] ;
    rr:subjectMap [ rr:template "kenmerk/{measSubject}" ; rr:termType rr:BlankNode ; rr:class impl:Verkeerssnelheidsmetingkenmerk ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerssnelheidsmetingkenmerk.kenmerktype ;
        rr:objectMap [ rr:constant VkmVerkeersKenmerkType:tijdsgemiddelde_snelheid ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate verkeer:voertuigType ;
        rr:objectMap [ rr:template "https://data.vlaanderen.be/id/concept/VkmVoertuigType/{vehicle}" ; rr:termType rr:IRI ]
    ] ;
    # measure direction: HARD-CODED to bothDirections.
    rr:predicateObjectMap [
        rr:predicate impl:Verkeerssnelheidsmetingkenmerk.meetrichting ;
        rr:objectMap [ rr:constant LinkDirectionValue:bothDirections ]
    ] .
