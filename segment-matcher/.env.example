WFS_URL=https://data.mobility.brussels/geoserver/bm_network/wfs
WFS_LAYER=bm_network:brr_segments_direction
MATCH_RADIUS=50
TIE_THRESHOLD=0.05
# openlr or naive. With openlr, a request missing orientation or road_type
# falls back to naive automatically (avoids a fabricated bearing skewing the match).
SCORER=openlr
# always (top two candidates, any level) or cross-level (surface vs non-surface only).
TIE_MODE=always
HOST=0.0.0.0
PORT=8000
