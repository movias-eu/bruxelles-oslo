# RML mapping: traverse FeatureCollection -> OSLO Verkeersmeetpunt RDF.
#
# Hand-authored RML/Turtle (RMLMapper consumes this directly; no YARRRML compile
# step). Models the measure-LOCATION shape from oslo-mapping/bike_devices.ttl:
# each traverse becomes a verkeer:Verkeersmeetpunt with an sf:Point WKT geometry.
#
# Input: the GeoJSON FeatureCollection from traffic/oslo/preprocess.py, written
# to a file whose path is given as the logical source (the command fills it in).
# The geometry.wkt is pre-built (WGS84 POINT) by the preprocessor.

@base <http://example.org/rules/> .
@prefix rr:         <http://www.w3.org/ns/r2rml#> .
@prefix rml:        <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:         <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix loc:        <http://example.org/id/measureLocation/> .
@prefix verkeer:    <https://data.vlaanderen.be/ns/verkeersmetingen#> .
@prefix impl:       <https://implementatie.data.vlaanderen.be/ns/verkeersmetingen-uitwisseling#> .
@prefix dv-weg:     <https://data.vlaanderen.be/ns/weg#> .
@prefix dv-netwerk: <https://data.vlaanderen.be/ns/netwerk#> .
@prefix iso-sp:     <http://def.isotc211.org/iso19156/2011/SamplingPoint#> .
@prefix geo:        <http://www.opengis.net/ont/geosparql#> .
@prefix sf:         <http://www.opengis.net/ont/sf#> .
@prefix iso-mp:     <http://def.isotc211.org/iso19103/2005/MeasureProfile#> .
@prefix schema:     <http://schema.org/> .
@prefix cdt:        <https://w3id.org/cdt/> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix LinkDirectionValue: <http://inspire.ec.europa.eu/codelist/LinkDirectionValue/> .

<#Verkeersmeetpunt>
    rml:logicalSource [
        rml:source "SOURCE.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.features[*]"
    ] ;
    rr:subjectMap [
        rr:template "http://example.org/id/measureLocation/{properties.name}" ;
        rr:class verkeer:Verkeersmeetpunt
    ] ;
    rr:predicateObjectMap [
        rr:predicate iso-sp:SF_SamplingPoint.shape ;
        rr:objectMap [ rr:parentTriplesMap <#Shape> ]
    ] ;
    # The sampled object: each segment match becomes a directed road segment.
    # Joined to its traverse on properties.name (a traverse may have many
    # matches; only traverses WITH matches get a bemonsterdObject).
    rr:predicateObjectMap [
        rr:predicate verkeer:bemonsterdObject ;
        rr:objectMap [
            rr:parentTriplesMap <#Rijrichting> ;
            rr:joinCondition [
                rr:child "properties.name" ;
                rr:parent "parentName"
            ]
        ]
    ] ;
    # Network reference: the point's position (offset, in metres) along the
    # matched segment. Mirrors bike_devices' Puntreferentie -> opPositie shape.
    rr:predicateObjectMap [
        rr:predicate impl:Verkeersmeetpunt.verkeersmeetpuntnetwerkreferentie ;
        rr:objectMap [
            rr:parentTriplesMap <#Puntreferentie> ;
            rr:joinCondition [
                rr:child "properties.name" ;
                rr:parent "parentName"
            ]
        ]
    ] .

<#Shape>
    rml:logicalSource [
        rml:source "SOURCE.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.features[*]"
    ] ;
    rr:subjectMap [
        # Blank node: the geometry has no identity of its own. The template
        # gives each feature a DISTINCT blank node (one per traverse) rather
        # than collapsing them into a single shared one.
        rr:template "geometry/{properties.name}" ;
        rr:termType rr:BlankNode ;
        rr:class sf:Point
    ] ;
    rr:predicateObjectMap [
        rr:predicate geo:asWKT ;
        rr:objectMap [
            rml:reference "wkt" ;
            rr:datatype geo:wktLiteral
        ]
    ] .

# --- Segment match -> directed road segment (mirrors bike_devices.ttl) --------
# Iterates the FLAT segmentMatches array the preprocessor builds (one entry per
# match, each carrying parentName + segmentId). One Rijrichting per match.
<#Rijrichting>
    rml:logicalSource [
        rml:source "SOURCE.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.segmentMatches[*]"
    ] ;
    rr:subjectMap [
        rr:template "rijrichting/{parentName}/{matchId}" ;
        rr:termType rr:BlankNode ;
        rr:class dv-weg:Rijrichting
    ] ;
    # HARD-CODED direction: the traverses table has a `direction` column, but it
    # is empty/inconsistent (96% null, mixed coding), so we cannot derive a
    # reliable LinkDirectionValue from it yet. Default to bothDirections.
    # TODO: replace with the real direction once the source column is cleaned up.
    rr:predicateObjectMap [
        rr:predicate dv-weg:rijrichting ;
        rr:objectMap [
            rr:constant LinkDirectionValue:bothDirections
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate impl:Rijrichting.netwerkreferentieelement ;
        rr:objectMap [ rr:parentTriplesMap <#Wegsegment> ;
            rr:joinCondition [
                rr:child "matchId" ;
                rr:parent "matchId"
            ]
        ]
    ] .

# Wegsegment with its line geometry + begin/end nodes (mirrors bike_devices.ttl).
# line/start/end WKT are derived from the match's WKB by the preprocessor.
<#Wegsegment>
    rml:logicalSource [
        rml:source "SOURCE.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.segmentMatches[*]"
    ] ;
    rr:subjectMap [
        rr:template "wegsegment/{segmentId}" ;
        rr:termType rr:BlankNode ;
        rr:class dv-weg:Wegsegment
    ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:Link.geometriemiddellijn ;
        rr:objectMap [ rr:parentTriplesMap <#SegmentLine> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:beginknoop ;
        rr:objectMap [ rr:parentTriplesMap <#BeginKnoop> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:eindknoop ;
        rr:objectMap [ rr:parentTriplesMap <#EindKnoop> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] .

<#SegmentLine>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    # Class is templated from lineType (LineString | MultiLineString) so the
    # node's sf: type matches its actual geometry -- NOT hard-coded. The sf:
    # term names match shapely's geom_type exactly.
    rr:subjectMap [
        rr:template "segmentline/{matchId}" ;
        rr:termType rr:BlankNode
    ] ;
    # rdf:type templated from lineType -> sf:LineString or sf:MultiLineString.
    # (rr:class only takes a constant, so the type is set via a predicateObjectMap.)
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:template "http://www.opengis.net/ont/sf#{lineType}" ; rr:termType rr:IRI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate geo:asWKT ;
        rr:objectMap [ rml:reference "lineWkt" ; rr:datatype geo:wktLiteral ]
    ] .

<#BeginKnoop>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "beginknoop/{matchId}" ; rr:termType rr:BlankNode ; rr:class dv-netwerk:Knoop ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:Knoop.geometrie ;
        rr:objectMap [ rr:parentTriplesMap <#BeginKnoopGeom> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] .

<#BeginKnoopGeom>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "beginknoopgeom/{matchId}" ; rr:termType rr:BlankNode ; rr:class sf:Point ] ;
    rr:predicateObjectMap [
        rr:predicate geo:asWKT ;
        rr:objectMap [ rml:reference "startWkt" ; rr:datatype geo:wktLiteral ]
    ] .

<#EindKnoop>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "eindknoop/{matchId}" ; rr:termType rr:BlankNode ; rr:class dv-netwerk:Knoop ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:Knoop.geometrie ;
        rr:objectMap [ rr:parentTriplesMap <#EindKnoopGeom> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] .

<#EindKnoopGeom>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "eindknoopgeom/{matchId}" ; rr:termType rr:BlankNode ; rr:class sf:Point ] ;
    rr:predicateObjectMap [
        rr:predicate geo:asWKT ;
        rr:objectMap [ rml:reference "endWkt" ; rr:datatype geo:wktLiteral ]
    ] .

# --- Point reference at the offset position along the segment -----------------
<#Puntreferentie>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "puntref/{matchId}" ; rr:termType rr:BlankNode ; rr:class dv-netwerk:Puntreferentie ] ;
    rr:predicateObjectMap [
        rr:predicate dv-netwerk:Puntreferentie.opPositie ;
        rr:objectMap [ rr:parentTriplesMap <#OpPositie> ;
            rr:joinCondition [ rr:child "matchId" ; rr:parent "matchId" ] ]
    ] .

<#OpPositie>
    rml:logicalSource [ rml:source "SOURCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$.segmentMatches[*]" ] ;
    rr:subjectMap [ rr:template "oppositie/{matchId}" ; rr:termType rr:BlankNode ; rr:class iso-mp:Length ] ;
    rr:predicateObjectMap [
        rr:predicate schema:unitCode ;
        rr:objectMap [ rr:constant "m" ; rr:datatype cdt:ucumunit ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:value ;
        rr:objectMap [ rml:reference "offset" ; rr:datatype xsd:double ]
    ] .
